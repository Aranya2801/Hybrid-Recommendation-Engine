# Copy this file to .env and fill in real values for local development.
# In Kubernetes, these are injected via deployment/k8s/configmap.yaml and
# deployment/k8s/secret.yaml instead.

ENVIRONMENT=development

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=60

# --- Cache ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- MLOps ---
MLFLOW_TRACKING_URI=file:./mlruns
MODEL_STORE_DIR=./models_store
WANDB_API_KEY=
WANDB_PROJECT=hybrid-recommendation-engine

# --- Data ---
MOVIELENS_DATA_DIR=./data/raw/movielens-small

# --- CORS ---
CORS_ORIGINS=http://localhost:3000
